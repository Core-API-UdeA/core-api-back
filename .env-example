DATABASE_URL="postgresql://postgres.example:password@example-host:5432/postgres?sslmode=require"

PREFIX="/scapi"

JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="4h"
JWT_ISSUER="core-api-auth"

GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GOOGLE_CLIENT_ID="your_google_client_id"

REGISTER_USER="your_email@example.com"
REGISTER_PASS="your_email_app_password"
REGISTER_FROM="your_email@example.com"
EMAIL_CONFIRMATION_TOKEN_TTL=86400000
URL_CONFIRMACION="https://your-frontend.example.com/confirmation/"

MERCADO_PAGO_ACCESS_TOKEN="your_mercado_pago_access_token"
MERCADO_PAGO_PUBLIC_KEY="your_mercado_pago_public_key"
MERCADO_PAGO_MODE="sandbox"

BASE_URL="https://your-backend.example.com"
FRONTEND_URL="https://your-frontend.example.com"

PLATFORM_FEE_PERCENTAGE=10

GATEWAY_ENCRYPTION_KEY="your_64_character_hex_encryption_key"
GROQ_API_KEY="your_groq_api_key"
